# ============================================================
# Node Identity
# ============================================================
NODE_ID=node-1
NODE_HOST=0.0.0.0
NODE_PORT=8000

# ============================================================
# Cluster (comma-separated host:port, including self)
# ============================================================
CLUSTER_NODES=localhost:8000,localhost:8001,localhost:8002

# ============================================================
# Raft Consensus
# ============================================================
ELECTION_TIMEOUT_MIN=1.5
ELECTION_TIMEOUT_MAX=3.0
HEARTBEAT_INTERVAL=0.5
RAFT_RPC_TIMEOUT=1.0

# ============================================================
# Redis
# ============================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ============================================================
# Distributed Queue
# ============================================================
QUEUE_REPLICAS=3
QUEUE_MAX_SIZE=10000
QUEUE_ACK_TIMEOUT=30.0

# ============================================================
# Distributed Cache
# ============================================================
CACHE_SIZE=1000
CACHE_POLICY=LRU

# ============================================================
# Lock Manager
# ============================================================
LOCK_LEASE_DURATION=30.0
LOCK_RETRY_INTERVAL=0.1
DEADLOCK_DETECTION_INTERVAL=5.0

# ============================================================
# Failure Detector
# ============================================================
FAILURE_TIMEOUT=5.0
PING_INTERVAL=1.0

# ============================================================
# Observability
# ============================================================
METRICS_PORT=9090
LOG_LEVEL=INFO
